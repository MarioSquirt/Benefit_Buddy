import csv
import sqlite3

conn = sqlite3.connect("brma_lookup.db")
cur = conn.cursor()

cur.execute("""
CREATE TABLE lookup (
    postcode TEXT PRIMARY KEY,
    brma TEXT,
    country TEXT
)
""")

with open("pcode_brma_lookup.csv", encoding="utf-8") as f:
    reader = csv.DictReader(f)
    rows = [
        (row["PCDS"].strip().upper(), row["brma_name"].strip(), row["country"].strip().upper())
        for row in reader
        if row["PCDS"].strip()
    ]

cur.executemany("INSERT INTO lookup VALUES (?, ?, ?)", rows)
conn.commit()
conn.close()
